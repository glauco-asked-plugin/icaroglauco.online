{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "noEmit": true,
    "skipLibCheck": true,
    "types": [
      "vite/client"
    ],
    "allowImportingTsExtensions": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.js",
    "scripts/**/*.mjs",
    "vite.config.js",
    "eslint.config.mjs"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
